{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "php artisan migrate --force && php -S 0.0.0.0:${PORT:-8080} -t public",
    "restartPolicyMaxRetries": 5
  },
  "plugins": [
    "mysql",
    "php"
  ]
}
