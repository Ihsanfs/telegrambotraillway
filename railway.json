{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "nixpacksVersion": "latest"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "vendor/bin/heroku-php-apache2 public/",
    "restartPolicyMaxRetries": 5
  },
  "plugins": [
    "mysql",
    "php"
  ]
}
